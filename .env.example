# ── Required ──────────────────────────────────────────────────────────────────
ADMIN_TOKEN=change-me-secret          # Protects the /admin dashboard
OC_ADMIN_PASSWORD=admin               # OpenCloud admin account password

# ── OpenCloud connection ──────────────────────────────────────────────────────
OC_URL=https://cloud.opencloud.test
OC_ADMIN_USER=admin
OC_INSECURE=true                      # Set true when using self-signed certs (dev)

# ── App behaviour ─────────────────────────────────────────────────────────────
REGISTRATION_MODE=open                # open | approval
APP_BASE_URL=https://register.opencloud.test

# ── Deployment (add-on mode) ──────────────────────────────────────────────────
REGISTRATION_DOMAIN=register.opencloud.test
REGISTRATION_APP_PATH=../opencloud-registration   # Path from pl-opencloud-server/

# ── Optional ──────────────────────────────────────────────────────────────────
DB_PATH=/data/registration.db
LISTEN_ADDR=:8080
LOG_DRIVER=local
